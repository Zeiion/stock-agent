# Stock Agent — environment configuration example.
# Copy to ".env" (cp .env.example .env) and edit. Everything has a safe default;
# the app runs out of the box with NO keys (yfinance data, claude/codex CLI for AI,
# macOS desktop notifications). Optional keys unlock real-time data / faster AI / push.
#
# Booleans accept: 1 / true / yes / on  (anything else = false).

# ----------------------------------------------------------------------------- #
# Server
# ----------------------------------------------------------------------------- #
HOST=127.0.0.1
PORT=8848

# ----------------------------------------------------------------------------- #
# Storage
# ----------------------------------------------------------------------------- #
# SQLite file path. Default: <project>/data/stockagent.db
DB_PATH=

# ----------------------------------------------------------------------------- #
# Data polling
# ----------------------------------------------------------------------------- #
POLL_INTERVAL_S=5             # watchlist poll interval while a market is OPEN (seconds)
POLL_INTERVAL_OFFHOURS_S=30   # poll interval while all markets are CLOSED (seconds)
HISTORY_LOOKBACK_DAYS=200     # bars of history to warm indicators / charts

# ----------------------------------------------------------------------------- #
# Data sources
# ----------------------------------------------------------------------------- #
# Finnhub gives real-time US quotes. Leave blank to use yfinance for US too.
FINNHUB_API_KEY=
# Prefer akshare (near-real-time, no key) for A-shares; falls back to yfinance.
PREFER_AKSHARE_FOR_CN=true

# ----------------------------------------------------------------------------- #
# AI brain
# ----------------------------------------------------------------------------- #
# provider: auto | anthropic | claude | codex
#   anthropic = Anthropic Messages API (needs ANTHROPIC_API_KEY)
#   claude    = local `claude -p` CLI   (uses your existing CLI login, NO key)
#   codex     = local `codex exec` CLI  (uses your existing CLI login, NO key)
#   auto      = anthropic if key present, else claude, with graceful fallback
AI_PROVIDER=auto
AI_ENSEMBLE=false             # cross-check high-conviction calls with a second AI tier
ANTHROPIC_API_KEY=           # only needed for the "anthropic" tier
CLAUDE_MODEL=claude-opus-4-8 # model id for the anthropic API and the claude CLI
CODEX_MODEL=                 # blank = codex CLI default
AI_TIMEOUT_S=180             # per-call AI timeout (seconds)
AI_LOGIN_SHELL=true          # spawn claude/codex via `zsh -lc` (needed: they are shell aliases)

# ----------------------------------------------------------------------------- #
# Notifications (routed by severity; first available channel wins)
# ----------------------------------------------------------------------------- #
NOTIFY_DESKTOP=true                    # macOS Notification Center
BARK_URL=                              # https://api.day.app/<your-key>
NTFY_URL=                              # https://ntfy.sh/<your-topic>
TELEGRAM_BOT_TOKEN=                    # both token AND chat id required for Telegram
TELEGRAM_CHAT_ID=
FEISHU_WEBHOOK=                        # 飞书 group bot webhook
DINGTALK_WEBHOOK=                      # 钉钉 group bot webhook
WECOM_WEBHOOK=                         # 企业微信 group bot webhook
# Email (both SMTP_HOST and SMTP_TO required to enable):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=

# ----------------------------------------------------------------------------- #
# Trading (signal-only / paper by default — NEVER places real orders)
# ----------------------------------------------------------------------------- #
TRADING_MODE=signal           # signal | paper   (kill-switch: set back to "signal")
REQUIRE_HUMAN_APPROVAL=true   # paper orders sit as "pending" until you approve them
MAX_POSITION_VALUE=100000     # max market value per single position

# ----------------------------------------------------------------------------- #
# Behaviour
# ----------------------------------------------------------------------------- #
AUTO_AI_ON_CRITICAL=true      # auto-run an AI analysis when a CRITICAL alert fires
# Comma-separated CORS origins (frontend dev server etc.):
CORS_ORIGINS=http://localhost:8888,http://127.0.0.1:8888
